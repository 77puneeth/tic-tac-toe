import java.util.*;

public class Main8 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int pin = 1234, attempts = 0;
        double bal = 1000;

        while (attempts < 3) {
            System.out.print("Enter PIN: ");
            int input = sc.nextInt();

            if (input == pin) {
                System.out.println("Balance: " + bal);
                return;
            } else {
                System.out.println("Wrong PIN");
                attempts++;
            }
        }
    }
}
